{
  "manifest_version": 3,
  "name": "Chat With Page AI",
  "version": "1.0",
  "description": "Chat with any webpage using AI",

  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Toggle AI Assistant"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}